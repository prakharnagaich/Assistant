# ── Helper: load TTS engine ───────────────────────────────────────────────────
@st.cache_resource(show_spinner=False)
def load_tts_model(model_name: str):
    """Load Coqui TTS model. Cached across reruns."""
    from TTS.api import TTS
    import torch
    device = "cuda" if torch.cuda.is_available() else "cpu"
    tts = TTS(model_name=model_name, progress_bar=False).to(device)
    return tts, device


def get_audio_info(wav_path: str) -> dict:
    """Return duration, sample rate, and channel count of a WAV file."""
    import soundfile as sf
    data, sr = sf.read(wav_path)
    duration = len(data) / sr
    channels = 1 if data.ndim == 1 else data.shape[1]
    return {"duration": duration, "sr": sr, "channels": channels, "samples": len(data)}


def preprocess_audio(uploaded_file) -> str:
    """
    Save uploaded file to a temp path.
    Resample to 16 kHz mono if needed (required by XTTS encoder).
    Returns path to processed WAV.
    """
    import soundfile as sf
    import librosa

    tmp_in = tempfile.NamedTemporaryFile(suffix=".wav", delete=False)
    tmp_in.write(uploaded_file.read())
    tmp_in.flush()
    tmp_in.close()

    audio, sr = librosa.load(tmp_in.name, sr=None, mono=True)
    if sr != 16000:
        audio = librosa.resample(audio, orig_sr=sr, target_sr=16000)
    
    out_path = tmp_in.name.replace(".wav", "_processed.wav")
    sf.write(out_path, audio, 16000, subtype="PCM_16")
    os.unlink(tmp_in.name)
    return out_path


