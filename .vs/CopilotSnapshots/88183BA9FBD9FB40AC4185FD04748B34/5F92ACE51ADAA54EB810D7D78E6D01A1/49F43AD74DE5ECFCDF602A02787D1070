def initialize_gemini(api_key: str):
    """Configure Gemini and return a chat session."""
    genai.configure(api_key=api_key)
    model = genai.GenerativeModel(
        model_name="gemini-2.5-flash",
        system_instruction=(
            "You are Nova, a friendly and concise voice assistant. "
            "Always reply in short, natural sentences suitable for speech. "
            "Never use bullet points, markdown, asterisks, or special characters. "
            "Be warm, helpful, and get to the point quickly."
        ),
    )
    return model.start_chat(history=[])


def transcribe_audio(audio_bytes: bytes) -> Tuple[str, bool]:
    """Convert audio bytes → text using Google Web Speech API (free)."""
    recognizer = sr.Recognizer()
    try:
        audio_file = io.BytesIO(audio_bytes)
        with sr.AudioFile(audio_file) as source:
            recognizer.adjust_for_ambient_noise(source, duration=0.3)
            audio_data = recognizer.record(source)
        text = recognizer.recognize_google(audio_data)
        return text, True
    except sr.UnknownValueError:
        return "Could not understand the audio. Please try again.", False
    except sr.RequestError as e:
        return f"Speech recognition service error: {e}", False
    except Exception as e:
        return f"Transcription error: {e}", False


def ask_gemini(user_text: str) -> Tuple[str, bool]:
    """Send text to Gemini and return the response."""
    try:
        response = st.session_state.chat_session.send_message(user_text)
        return response.text.strip(), True
    except Exception as e:
        return f"Gemini error: {e}", False


def synthesize_speech(text: str) -> Optional[bytes]:
    """Convert text → audio bytes using gTTS (free, online)."""
    try:
        buf = io.BytesIO()
        gTTS(text=text, lang="en", slow=False).write_to_fp(buf)
        buf.seek(0)
        return buf.read()
    except Exception:
        return None


def add_log(user_text: str, ai_text: str):
    """Append a new entry to the interaction log."""
    st.session_state.logs.append({
        "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "user": user_text,
        "assistant": ai_text,
    })


