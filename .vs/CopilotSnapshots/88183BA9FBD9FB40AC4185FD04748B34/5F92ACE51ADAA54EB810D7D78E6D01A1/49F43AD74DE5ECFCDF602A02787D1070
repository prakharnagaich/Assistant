                                color:#00ffab; margin-top:8px;">
                        🗣️ <em>"{user_text}"</em>
                    </div>
                    """, unsafe_allow_html=True)
                    process_triggered = True
                else:
                    st.warning(user_text)

        if send_text and text_fallback.strip():
            user_text        = text_fallback.strip()
            process_triggered = True
            # Clear the text input after triggering
            st.session_state.text_input_area = ""

        # ── Call Gemini + TTS ──
        # Only process if triggered AND text is different from last processed input
        if process_triggered and user_text and user_text != st.session_state.last_processed_input:
            st.session_state.processing = True
            st.session_state.last_processed_input = user_text

            with st.spinner("🤖 Nova is thinking…"):
                ai_text, ok = ask_gemini(user_text)

            if ok:
                st.session_state.last_user_text = user_text
                st.session_state.last_ai_text   = ai_text

                with st.spinner("🔊 Generating voice reply…"):
                    audio_out = synthesize_speech(ai_text)
                    st.session_state.last_audio_bytes = audio_out

                add_log(user_text, ai_text)
                st.session_state.processing = False
                st.rerun()
            else:
                st.error(ai_text)
                st.session_state.processing = False

        # ── Play latest reply ──
        if st.session_state.last_audio_bytes:
            st.markdown("""
