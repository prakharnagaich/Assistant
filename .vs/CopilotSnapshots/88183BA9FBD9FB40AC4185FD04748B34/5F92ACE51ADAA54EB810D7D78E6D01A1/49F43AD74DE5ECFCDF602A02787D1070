<script>
/* ── Constants ────────────────────────────────────────────── */
const API_KEY   = "__GEMINI_KEY__";
const MODEL     = "gemini-2.0-flash";
const STREAM_URL = `https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:streamGenerateContent?alt=sse&key=${API_KEY}`;
const SYS_PROMPT = "You are Nova, a friendly and concise voice assistant. Always reply in short natural sentences suitable for speech. Never use bullet points markdown asterisks or special characters. Be warm helpful and get to the point quickly.";

/* ── State ────────────────────────────────────────────────── */
let isActive      = false;   // User wants listening ON
let isListening   = false;   // recognition is running
let isSpeaking    = false;   // TTS is playing / AI not yet done
let recognition   = null;
let silTimer      = null;
let finalTx       = "";
let interimTx     = "";
let history       = [];      // Gemini conversation history [{role,parts}]
let ttsQueue      = [];
let ttsPlaying    = false;
let selectedVoice = null;

/* ── Browser support check ────────────────────────────────── */
if (!("webkitSpeechRecognition" in window) && !("SpeechRecognition" in window)) {
  document.getElementById("warn").style.display = "block";
}

/* ── Voices ───────────────────────────────────────────────── */
function loadVoices() {
  const vs = speechSynthesis.getVoices();
  selectedVoice =
    vs.find(v => v.name.includes("Google") && v.lang.startsWith("en")) ||
    vs.find(v => v.lang.startsWith("en-US")) ||
    vs.find(v => v.lang.startsWith("en")) ||
    vs[0] || null;
}
speechSynthesis.onvoiceschanged = loadVoices;
loadVoices();

/* ── Build waveform bars ──────────────────────────────────── */
const VIZ   = document.getElementById("viz");
const PEAKS = [10,18,30,42,36,48,26,14,32,46,38,22,44,16,28,12];
PEAKS.forEach((h, i) => {
  const b = document.createElement("div");
  b.className = "bar";
  b.style.setProperty("--h", h + "px");
  b.style.setProperty("--d", (.06 * i + .1) + "s");
  VIZ.appendChild(b);
});
function vizState(s) {
  VIZ.querySelectorAll(".bar").forEach(b => {
    b.className = s === "idle" ? "bar" : "bar " + s;
    if (s === "idle") b.style.height = "4px"; else b.style.height = "";
  });
}

/* ── UI helpers ───────────────────────────────────────────── */
function setStatus(cls, text, detail = "") {
  document.getElementById("s-dot").className = cls;
  document.getElementById("s-text").textContent = text;
  document.getElementById("s-detail").textContent = detail;
  vizState(cls === "idle" || cls === "error" ? "idle" :
           cls === "listening" ? "l" : cls === "thinking" ? "t" : "s");
}

function setTx(fin, itr) {
  const c = document.getElementById("tx-card");
  if (!fin && !itr) {
    c.className = "";
    c.textContent = "Live transcript will appear here while you speak…";
  } else {
    c.className = "active";
    c.innerHTML = `<span class="tx-final">${fin}</span><span class="tx-interim">${itr}</span>`;
  }
}

function showErr(msg, ms = 4000) {
  const t = document.getElementById("err-toast");
  t.textContent = "⚠ " + msg;
  t.style.display = "block";
  setTimeout(() => t.style.display = "none", ms);
}

function updateQueueBadge() {
  const b = document.getElementById("queue-badge");
  if (ttsQueue.length > 0) {
    b.textContent = ttsQueue.length + " chunk(s) queued";
    b.style.display = "inline-block";
  } else {
    b.style.display = "none";
  }
}

function addMsg(role, text) {
  const d = document.createElement("div");
  d.className = role === "user" ? "mu" : "ma";
  d.innerHTML = `<div class="ml">${role === "user" ? "YOU" : "NOVA"}</div><div>${text}</div>`;
  document.getElementById("conv").appendChild(d);
  document.getElementById("conv").scrollTop = 1e9;
}

/* ── Silence countdown bar ────────────────────────────────── */
function startSilBar() {
  const w = document.getElementById("sil-wrap");
  const b = document.getElementById("sil-bar");
  w.style.display = "block";
  b.style.transition = "none";
  b.style.width = "0%";
  requestAnimationFrame(() => requestAnimationFrame(() => {
    b.style.transition = "width 2s linear";
    b.style.width = "100%";
  }));
}
function stopSilBar() {
  document.getElementById("sil-wrap").style.display = "none";
  const b = document.getElementById("sil-bar");
  b.style.transition = "none";
  b.style.width = "0%";
}

/* ── Speech Recognition ───────────────────────────────────── */
function buildRecognition() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) return null;
  const r = new SR();
  r.continuous      = true;
  r.interimResults  = true;
  r.lang            = "en-US";
  r.maxAlternatives = 1;

  r.onstart = () => {
    isListening = true;
    setStatus("listening", "🎙️ Listening…", "Speak now — 2 s silence sends");
  };

  r.onend = () => {
    isListening = false;
    // Auto-restart unless user explicitly stopped or TTS is playing
    if (isActive && !isSpeaking) {
      setTimeout(() => {
        if (isActive && !isSpeaking && !isListening) {
          try { r.start(); } catch (_) {}
        }
      }, 120);
    }
  };

  r.onerror = e => {
    if (e.error === "no-speech" || e.error === "aborted") return;
    console.warn("SR error:", e.error);
  };

  r.onresult = event => {
    // Any new speech → reset the silence timer
    clearTimeout(silTimer);
    stopSilBar();

    let nFin = "", interim = "";
    for (let i = event.resultIndex; i < event.results.length; i++) {
      if (event.results[i].isFinal) nFin   += event.results[i][0].transcript;
      else                          interim += event.results[i][0].transcript;
    }
    finalTx  += nFin;
    interimTx = interim;

    setTx(finalTx, interimTx);
    setStatus("listening", "🎙️ Listening…",
      '"' + (finalTx + interimTx).slice(-36) + (finalTx + interimTx).length > 36 ? "…" : "" + '"');

    // Restart 2-second silence timer
    startSilBar();
    silTimer = setTimeout(async () => {
      const full = (finalTx + interimTx).trim();
      if (!full) return;
      finalTx = ""; interimTx = "";
      setTx("", "");
      stopSilBar();
      await processInput(full);
    }, 2000);
  };

  return r;
}

/* ── Start / Stop listening ───────────────────────────────── */
function startListening() {
  if (isSpeaking || !isActive) return;
  if (!recognition) recognition = buildRecognition();
  if (!recognition) return;
  if (!isListening) {
    try { recognition.start(); } catch (_) {}
  }
}

function stopListening(deactivate = true) {
  clearTimeout(silTimer);
  stopSilBar();
  if (deactivate) isActive = false;
  isListening = false;
  try { recognition && recognition.abort(); } catch (_) {}
}

/* ── TTS queue ────────────────────────────────────────────── */
function enqueueTTS(text) {
  if (!text.trim()) return;
  ttsQueue.push(text.trim());
  updateQueueBadge();
  if (!ttsPlaying) playNext();
}

function playNext() {
  if (ttsQueue.length === 0) {
    ttsPlaying = false;
    isSpeaking = false;
    document.getElementById("btn-stop-tts").style.display = "none";
    updateQueueBadge();
    if (isActive) {
      startListening();
      setStatus("listening", "🎙️ Listening…", "Your turn");
    } else {
      setStatus("idle", "Quick Voice paused", "");
    }
    return;
  }
  ttsPlaying = true;
  isSpeaking = true;
  document.getElementById("btn-stop-tts").style.display = "inline-block";
  const chunk = ttsQueue.shift();
  updateQueueBadge();

  const utt = new SpeechSynthesisUtterance(chunk);
  if (selectedVoice) utt.voice = selectedVoice;
  utt.rate   = 1.05;
  utt.pitch  = 1.0;
  utt.volume = 1.0;
  utt.onstart = () => {
    setStatus("speaking", "🔊 Nova is speaking…",
      ttsQueue.length ? `+${ttsQueue.length} more` : "");
  };
  utt.onend   = () => playNext();
  utt.onerror = e => { if (e.error !== "interrupted") console.warn("TTS:", e.error); playNext(); };
  speechSynthesis.speak(utt);
}

function stopTTS() {
  speechSynthesis.cancel();
  ttsQueue = [];
  ttsPlaying = false;
  isSpeaking = false;
  document.getElementById("btn-stop-tts").style.display = "none";
  updateQueueBadge();
  if (isActive) startListening();
}

/* ── Sentence break helper ────────────────────────────────── */
function sentenceBreak(text) {
  const m = [...text.matchAll(/[.!?]+\s+/g)];
  if (m.length) { const l = m[m.length - 1]; return l.index + l[0].length; }
  return -1;
}

/* ── Core: send user text to Gemini and stream TTS ────────── */
async function processInput(userText) {
  stopListening(false); // pause listening but keep isActive
  isSpeaking = true;

  addMsg("user", userText);
  setStatus("thinking", "🤔 Nova is thinking…", "");
  history.push({ role: "user", parts: [{ text: userText }] });

  let pending  = "";
  let fullResp = "";
  let ttsStarted = false;

  try {
    const res = await fetch(STREAM_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        system_instruction: { parts: [{ text: SYS_PROMPT }] },
        contents: history,
        generationConfig: { maxOutputTokens: 800, temperature: 0.8 }
      })
    });

    if (!res.ok) {
      let errMsg = `HTTP ${res.status}`;
      if (res.status === 401) errMsg = "Invalid or expired API key";
      else if (res.status === 429) errMsg = "Rate limit exceeded - too many requests";
      else if (res.status === 404) errMsg = "Model not found - check model name";
      else if (res.status === 403) errMsg = "Access denied - check API key permissions";
      throw new Error(errMsg);
    }

    const reader  = res.body.getReader();
    const decoder = new TextDecoder();
    let buf = "";

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;

      buf += decoder.decode(value, { stream: true });
      const lines = buf.split("\n");
      buf = lines.pop(); // keep partial line

      for (const line of lines) {
        if (!line.startsWith("data: ") || line.trim() === "data: [DONE]") continue;
        try {
          const d    = JSON.parse(line.slice(6));
          const text = d?.candidates?.[0]?.content?.parts?.[0]?.text;
          if (!text) continue;

          fullResp += text;
          pending  += text;

          // Trigger TTS when ≥10 words buffered
          const wc = pending.trim().split(/\s+/).length;
          if (wc >= 10) {
            const bp = sentenceBreak(pending);
            if (bp > 0) {
              enqueueTTS(pending.slice(0, bp));
              pending    = pending.slice(bp);
              ttsStarted = true;
            } else if (wc >= 16) {
              enqueueTTS(pending);
              pending    = "";
              ttsStarted = true;
            }
          }
        } catch (_) {}
      }
    }

    // Drain remaining buffer
    if (pending.trim()) { enqueueTTS(pending); ttsStarted = true; }

    // Save AI reply to history
    if (fullResp) {
      history.push({ role: "model", parts: [{ text: fullResp }] });
      addMsg("ai", fullResp);
    }

    // Nothing queued → resume immediately
    if (!ttsStarted) {
      isSpeaking = false;
      if (isActive) startListening();
    }

  } catch (err) {
    console.error(err);
    showErr("AI error: " + err.message);
    isSpeaking = false;
    addMsg("ai", "⚠️ Could not reach Nova. Check your API key.");
    if (isActive) setTimeout(startListening, 1500);
  }
}

/* ── Toggle main button ───────────────────────────────────── */
function toggleMain() {
  const btn = document.getElementById("btn-toggle");
  if (isActive) {
    stopListening(true);
    stopTTS();
    setStatus("idle", "Quick Voice paused", "Press Start to resume");
    btn.textContent = "🎙️ Start Listening";
    btn.classList.remove("on");
  } else {
    isActive = true;
    if (!recognition) recognition = buildRecognition();
    startListening();
    btn.textContent = "⏹ Stop";
    btn.classList.add("on");
  }
}

function clearConv() {
  history = [];
  document.getElementById("conv").innerHTML = "";
  finalTx = ""; interimTx = "";
  setTx("", "");
  ttsQueue = [];
  speechSynthesis.cancel();
  ttsPlaying = false; isSpeaking = false;
  updateQueueBadge();
}

/* ── Init ─────────────────────────────────────────────────── */
setStatus("idle", "Quick Voice ready", "Press Start to begin");
</script>
</body>
